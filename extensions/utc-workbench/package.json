{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "utc-workbench",
  "version": "1.0.0",
  "title": "UTC Workbench",
  "subtitle": "",
  "description": "Timestamp interpretation and timeline reconstruction for developer workflows",
  "icon": "icon.png",
  "author": "dfrancour",
  "categories": [
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "utc-workbench",
      "title": "UTC Workbench",
      "description": "Interpret timestamps and reconstruct event timelines",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.11",
    "@raycast/utils": "^2.2.3",
    "luxon": "^3.6.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/luxon": "^3.7.1",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "eslint": "^8.57.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  },
  "scripts": {
    "build": "ray build --skip-types -e dist -o dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "publish": "npx @raycast/api@latest publish",
    "prepublishOnly": "echo \"\\n\\nError: Use 'npm run publish' instead.\\n\" && exit 1",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  }
}
